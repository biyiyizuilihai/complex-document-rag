# P0 PDF RAG Demo
# 复制本文件为 .env 后填入实际值：
#   cp .env.example .env

# 必填：OpenAI 或兼容 OpenAI 的 API Key
OPENAI_API_KEY=your-api-key-here

# 如果你用 DashScope / Qwen，请取消注释：
# DASHSCOPE_API_KEY=your-dashscope-api-key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MULTIMODAL_LLM_MODEL=qwen-vl-max
# TEXT_LLM_MODEL=qwen-plus
# WEB_ANSWER_LLM_MODEL=qwen3.5-flash
# EMBEDDING_MODEL=text-embedding-v3

# Web 问答默认关闭 thinking，打开后前端会显示思考过程
# WEB_ANSWER_ENABLE_THINKING=false

# 可选：embedding 请求的轻量重试
# EMBEDDING_RETRY_COUNT=2
# EMBEDDING_RETRY_DELAY_SECONDS=0.6

# 可选：SiliconFlow rerank
# SILICONFLOW_API_KEY=your-siliconflow-api-key
# RERANK_API_BASE=https://api.siliconflow.cn/v1
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_ENABLED=true
# TEXT_RETRIEVAL_SCORE_THRESHOLD=0.55
# IMAGE_RETRIEVAL_SCORE_THRESHOLD=0.70
# TABLE_RETRIEVAL_SCORE_THRESHOLD=0.70
# TEXT_RETRIEVAL_SCORE_MARGIN=0.12
# IMAGE_RETRIEVAL_SCORE_MARGIN=0.08
# TABLE_RETRIEVAL_SCORE_MARGIN=0.08

# 本地 Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
